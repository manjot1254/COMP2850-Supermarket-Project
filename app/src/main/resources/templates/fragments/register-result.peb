{% if isRegistered %}
    <h1 class="success">You have successfully registered.</h1>
    <meta http-equiv="refresh" content="2;url=/" />
{% else %}
    <h1 class="error">Registration Failed</h1>
    <p>{{ registerMessage | default("Unknown error occurred.") }}</p>
    <meta http-equiv="refresh" content="3;url=/login" />
{% endif %}